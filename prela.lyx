\begin_inset Quotes eld
\end_inset

logical conjunction
\begin_inset Quotes erd
\end_inset

 inside 
\begin_inset listings
inline true
status open

\begin_layout Plain Layout
.with()
\end_layout

\end_inset

,
 as the semijoin ignores the second column of its right-hand-side.
 
\end_layout


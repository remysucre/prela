movie.(
    company.country == "[us]"
  & info.(type == "release dates" & (info ~ r"^Japan:.*200" | info ~ r"^USA:.*200"))
  & production_year > 2000
  : cast.(
        note in ("(voice)", "(voice: Japanese version)", "(voice) (uncredited)", "(voice: English version)")
      & role == "actress"
      & character
      & person.(gender == "f" & name ~ r"An" & aka)
    ).person
  , title
)

movie.(
    company.country == "[us]"
  & info.(type == "release dates" & (info ~ r"^Japan:.*201" | info ~ r"^USA:.*201"))
  & keyword in ("hero", "martial-arts", "hand-to-hand-combat")
  & production_year > 2010
  : cast.(
        note in ("(voice)", "(voice: Japanese version)", "(voice) (uncredited)", "(voice: English version)")
      & role == "actress"
      & person.(gender == "f" & name ~ r"An" & aka)
      : character, person
    )
  , title
)

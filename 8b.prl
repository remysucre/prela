movie.(
    company.(
        country == "[jp]"
      & note ~ r"\(Japan\)"
      & note !~ r"\(USA\)"
      & (note ~ r"\(2006\)" | note ~ r"\(2007\)")
    )
  & production_year >= 2006 & production_year <= 2007
  & (title ~ r"^One Piece" | title ~ r"^Dragon Ball Z")
  : cast.(
        note == "(voice: English version)"
      & role == "actress"
      & person.(name ~ r"Yo" & name !~ r"Yu")
    ).person.aka
  , title
)

movie.(
    complete_cast.(subject = 'cast' & status like '%complete%')
  & kind = 'movie'
  & keyword in ('superhero', 'marvel-comics', 'based-on-comic', 'tv-special', 'fight', 'violence', 'magnet', 'web', 'claw', 'laser')
  & production_year > 2000
  : cast.(character.(name like '%man%' | name like '%Man%')).character
  , data.(type = 'rating')
  , title
)

movie.(
    keyword in ("sequel", "revenge", "based-on-novel")
  & production_year > 1950
  & link
  : company.(
        country != "[pl]"
      & (name ~ r"^20th Century Fox" | name ~ r"^Twentieth Century Fox")
      & type != "production companies"
      & note
      : name, note
    )
  , title
)

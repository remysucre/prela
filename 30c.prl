movie.(
    complete_cast.(subject == "cast" & status == "complete+verified")
  & keyword in ("murder", "violence", "blood", "gore", "death", "female-nudity", "hospital")
  : info.(type == "genres" & info in ("Horror", "Action", "Sci-Fi", "Thriller", "Crime", "War"))
  , data.(type == "votes")
  , cast.(
        note in ("(writer)", "(head writer)", "(written by)", "(story)", "(story editor)")
      & person.gender == "m"
    ).person
  , title
)

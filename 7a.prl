movie.(
    production_year >= 1980 & production_year <= 1995
  & linked_by.type == "features"
  : cast.person.(
        aka.name ~ r"a"
      & name_pcode_cf >= "A" & name_pcode_cf <= "F"
      & (gender == "m" | (gender == "f" & name ~ r"^B"))
      & info.(type == "mini biography" & note == "Volker Boehm")
    )
  , title
)

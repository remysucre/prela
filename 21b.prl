movie.(
    keyword == "sequel"
  & production_year >= 2000 & production_year <= 2010
  & info.info in ("Germany", "German")
  : company.(
        country != "[pl]"
      & (name ~ r"Film" | name ~ r"Warner")
      & type == "production companies"
      - note
    )
  , link.(type ~ r"follow").type
  , title
)

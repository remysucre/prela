movie.(
    company.(country == "[us]" & note ~ r"\(200.*\)" & (note ~ r"\(USA\)" | note ~ r"\(worldwide\)"))
  & info.(type == "release dates" & (info ~ r"^Japan:.*2007" | info ~ r"^USA:.*2008"))
  & production_year >= 2007 & production_year <= 2008
  & title ~ r"Kung.*Fu.*Panda"
  : cast.(
        note == "(voice)"
      & role == "actress"
      & character
      & person.(gender == "f" & name ~ r"Angel" & aka)
    ).person
  , title
)

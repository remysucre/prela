movie.(
    complete_cast.(subject = 'cast' & status like '%complete%')
  & kind = 'movie'
  & keyword in ('superhero', 'marvel-comics', 'based-on-comic', 'fight')
  & production_year > 2005
  : cast.(character.(name like '%man%' | name like '%Man%')).character
  , data.(type = 'rating' & data > '8.0')
  , title
)

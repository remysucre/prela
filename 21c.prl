movie.(
    keyword == "sequel"
  & production_year >= 1950 & production_year <= 2010
  & info.info in ("Sweden", "Norway", "Germany", "Denmark", "Swedish", "Denish", "Norwegian", "German", "English")
  : company.(
        country != "[pl]"
      & (name ~ r"Film" | name ~ r"Warner")
      & type == "production companies"
      - note
    )
  , link.(type ~ r"follow").type
  , title
)

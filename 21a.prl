movie.(
    keyword = 'sequel'
  & production_year >= 1950 & production_year <= 2000
  & info.info in ('Sweden', 'Norway', 'Germany', 'Denmark', 'Swedish', 'Denish', 'Norwegian', 'German')
  : company.(
        country != '[pl]'
      & (name like '%Film%' | name like '%Warner%')
      & type = 'production companies'
      \ note
    )
  , link.(type like '%follow%').type
  , title
)

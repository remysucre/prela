movie.(
    info.(type == "countries" & info in ("Germany", "German", "USA", "American"))
  & keyword in ("murder", "murder-in-title", "blood", "violence")
  & production_year > 2008
  & kind in ("movie", "episode")
  : title
  , data.(data < "7.0" & type == "rating")
  , company.(
       note !~ r"\(USA\)" &
       note ~ r"\(200.*\)" &
       country != "[us]" &
       type == "production companies"
    )
)

movie.(
    kind == "tv series"
  : company.(country == "[nl]")
  , data.(type == "rating")
  , title
  , link.(
        type ~ r"follow"
      & target.(kind == "tv series" & production_year == 2007)
      : target.company
      , target.data.(type == "rating" & data < "3.0")
      , target.title
    )
)

movie.(
    info.(type = 'countries' & val in ('Germany', 'German', 'USA', 'American'))
  & keyword in ('murder', 'murder-in-title', 'blood', 'violence')
  : title.(production_year > 2008 & kind in ('movie', 'episode'))!
  , data.(val < '8.5' & type = 'rating')!
  , company.(
       note not like '%(USA)%' &
       note like '%(200%)%' &
       country != '[us]' & 
       type = 'production companies'
    ).name
)

movie.(
    keyword = 'sequel'
  & production_year = 1998
  & info.info in ('Sweden', 'Germany', 'Swedish', 'German')
  & complete_cast.(subject in ('cast', 'crew') & status = 'complete')
  : company.(
        country != '[pl]'
      & (name like '%Film%' | name like '%Warner%')
      & type = 'production companies'
      \ note
    )
  , link.(type like '%follow%').type
  , title
)

movie.(
    company.(country == "[us]" & note ~ r"\(200.*\)" & (note ~ r"\(USA\)" | note ~ r"\(worldwide\)"))
  & production_year >= 2007 & production_year <= 2010
  : cast.(
        note == "(voice)"
      & role == "actress"
      & person.(gender == "f" & name ~ r"Angel")
      : person.aka, character, person
    )
  , title
)

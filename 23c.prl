movie.(
    complete_cast.status == "complete+verified"
  & company.country == "[us]"
  & kind in ("movie", "tv movie", "video movie", "video game")
  & info.(type == "release dates" & note ~ r"internet" & (info ~ r"^USA:.* 199" | info ~ r"^USA:.* 200"))
  & production_year > 1990
  & keyword
  : kind
  , title
)

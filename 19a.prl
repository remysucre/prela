movie.(
    company.(country = '[us]' & (note like '%(USA)%' | note like '%(worldwide)%'))
  & info.(type = 'release dates' & (info like 'Japan:%200%' | info like 'USA:%200%'))
  & production_year >= 2005 & production_year <= 2009
  : cast.(
        note in ('(voice)', '(voice: Japanese version)', '(voice) (uncredited)', '(voice: English version)')
      & role = 'actress'
      & character
      & person.(gender = 'f' & name like '%Ang%' & aka)
    ).person
  , title
)

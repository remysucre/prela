movie.(
    company.(country == "[us]" & (note ~ r"\(USA\)" | note ~ r"\(worldwide\)"))
  & info.(type == "release dates" & (info ~ r"^Japan:.*200" | info ~ r"^USA:.*200"))
  & production_year >= 2005 & production_year <= 2009
  : cast.(
        note in ("(voice)", "(voice: Japanese version)", "(voice) (uncredited)", "(voice: English version)")
      & role == "actress"
      & character
      & person.(gender == "f" & name ~ r"Ang" & aka)
    ).person
  , title
)
